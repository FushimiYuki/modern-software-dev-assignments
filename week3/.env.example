# GitHub MCP Server Environment Variables

# Required: Your GitHub Personal Access Token
# Get one at: https://github.com/settings/tokens
# Recommended scopes: repo (for full access) or public_repo (for public repos only)
GITHUB_TOKEN=

# Optional: GitHub API base URL (defaults to https://api.github.com)
# GITHUB_API_BASE_URL=https://api.github.com

# Optional: Request timeout in seconds (default: 30)
# GITHUB_API_TIMEOUT=30

# Optional: Maximum retry attempts for failed requests (default: 3)
# GITHUB_API_MAX_RETRIES=3
